# ── Backend Server ─────────────────────────────────────────────────────────────
# URL of the Express API server (used by Vite's dev proxy)
VITE_SERVER_URL=http://localhost:3001

# ── API Endpoint ───────────────────────────────────────────────────────────────
# Relative path to the AI endpoint (proxied through Vite to the server above)
VITE_API_URL=/api/ai
